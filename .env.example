# Copy to `.env` and fill in only the providers you have keys for.
# Leave them all blank to run in mock/template mode (no internet required).

# --- LLM provider selection ---------------------------------------
# Choose one (precedence: gemini > openai > anthropic > mock).
# LLM_PROVIDER=gemini

# --- Google Gemini (free tier available) --------------------------
# Get a key at: https://aistudio.google.com/app/apikey
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-1.5-flash

# --- OpenAI -------------------------------------------------------
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# --- Anthropic Claude ---------------------------------------------
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-sonnet-4-6

# --- TTS (optional, free fallbacks always available) -------------
# ELEVENLABS_API_KEY=
# ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# --- Image generation overrides ----------------------------------
# Set to 1 to skip Pollinations.ai (the free default) and use OpenAI/SD.
# POLLINATIONS_DISABLE=
# SD_API_URL=http://127.0.0.1:7860

# --- REAL VIDEO GENERATION + LIP SYNC (recommended for best demo) ---
# fal.ai gives ~$1 of free trial credit which is enough for several
# pipelines; it powers BOTH text-to-video (Stable Video Diffusion,
# fast-SVD, CogVideoX) AND lip-sync (SadTalker, sync-lipsync).
# Get a key at https://fal.ai/dashboard/keys
# FAL_KEY=

# Replicate alternative (paid; SVD + Wav2Lip + SadTalker available)
# https://replicate.com/account/api-tokens
# REPLICATE_API_TOKEN=

# Hugging Face Inference API (free tier, lower quality text-to-video)
# https://huggingface.co/settings/tokens
# HF_TOKEN=

# --- App config --------------------------------------------------
# HOST=0.0.0.0
# PORT=8000
